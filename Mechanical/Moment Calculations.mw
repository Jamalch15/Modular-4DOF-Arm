<Group hide-input="false" labelreference="L16" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">m1:=0.13*Unit(kg); m2:=0.13*Unit(kg);mL:=0.44*Unit(kg/m);mE:=(0.2+0.5)*Unit(kg);</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
</Group>
<Group hide-input="false" labelreference="L17" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">L1:=0.15*Unit(m);L2:=0.15*Unit(m);LE:=0.1*Unit(m);L1e:=0.11*Unit(m);L2e:=0.11*Unit(m);LB:=0.0328*Unit(m);</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
</Group>
<Group hide-input="false" labelreference="L18" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">g := 9.82*Unit(m/s^2):
tau_1_g := g *( L1*m1
            + (L1+L2)*m2
            + (L1+L2+LE)*mE
            + (mL*L1e)*(L1/2)
            + (mL*L2e)*(L1 + L2/2) ):

tau_2_g := g *( L2*m2
            + (L2+LE)*mE
            + (mL*L2e)*(L2/2) ):

tau_3_g := g * LE*mE:

# About base motor:
# gravity torque is zero about the base z-axis for pure yaw
tau_B_g := 0*tau_1_g:
</Text-field>
</Input>
</Group>
<Group hide-input="false" labelreference="L19" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"># About motor1:
I1 := (1/3)*mL*L1e^3
    + (1/12)*(mL*L2e)*L2e^2 + (mL*L2e)*(L1 + L2/2)^2
    + m1*L1^2
    + m2*(L1+L2)^2
    + mE*(L1+L2+LE)^2:

# About motor 2:
I2 := (1/3)*mL*L2e^3
    + m2*L2^2
    + mE*(L2+LE)^2:

# About motor 3:
I3 := mE*LE^2:

# About base motor:
IB := (1/12)*(mL*L1e)*L1e^2 + (mL*L1e)*(LB + L1/2)^2
    + (1/12)*(mL*L2e)*L2e^2 + (mL*L2e)*(LB + L1 + L2/2)^2
    + m1*(LB + L1)^2
    + m2*(LB + L1 + L2)^2
    + mE*(LB + L1 + L2 + LE)^2:
</Text-field>
</Input>
</Group>
<Group hide-input="false" labelreference="L21" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">max_accel := 2*3.14 *Unit(1/s^2);</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
</Group>
<Group hide-input="false" labelreference="L23" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">tau_1_accel := I1*max_accel;
tau_2_accel := I2*max_accel:
tau_3_accel := I3*max_accel:
tau_B_accel := IB*max_accel:
</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
</Group>
<Group hide-input="false" labelreference="L20" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">tau_1 := simplify(tau_1_g + tau_1_accel);
tau_2 := simplify(tau_2_g + tau_2_accel);
tau_3 := simplify(tau_3_g + tau_3_accel);
tau_B := simplify(tau_B_g + tau_B_accel);</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
